{
  "manifest_version": 3,
  "name": "PetVet Care Centers Job Scraper",
  "version": "1.0",
  "description": "Scrapes job data from PetVet Care Centers careers page.",
  "permissions": ["activeTab", "storage", "scripting", "tabs", "offscreen", "webNavigation"],
  "host_permissions": [
    "https://www.petvetcarecenters.com/*",
    "https://petvetcarecenters.com/*",
    "https://www.google.com/maps/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.petvetcarecenters.com/*",
        "https://petvetcarecenters.com/*"
      ],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["description-scraper.js", "google-maps-scraper.js", "petvet-detail-extractor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
