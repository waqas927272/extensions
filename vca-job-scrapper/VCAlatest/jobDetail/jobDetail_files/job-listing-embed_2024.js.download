const BASE_API_URL = 'https://embed.vouchfor.com/v2';
const API_KEY = 'hBOzTLnR8Z-rjg62hZpvrZEATr6BrfdghIFle9IR0ZwafZV6GQxCLmDmoAJTc';
const FALLBACK_TAG = 'Default Playlist';
const FALLBACK_VOUCH = 'OHIJDjjWIV';
const TEMPLATE_ID = '4626a6e2-a10d-4d9a-a24c-597719c48164';

const script = document.createElement('script');
script.setAttribute('defer', true);
script.setAttribute('type', 'text/javascript');
script.setAttribute('src', 'https://cdn.jsdelivr.net/npm/@vouchfor/embeds@latest-v2/dist/iife/embeds.iife.js');
document.head.appendChild(script);

async function checkLocation() {
  let count = 0;

  try {
    const location = await new Promise((resolve, reject) => {
      const interval = setInterval(() => {
        const jobInfoElement = document.querySelector('.job-info');

        if (jobInfoElement) {
          clearInterval(interval);
          const jobLocation = jobInfoElement.querySelector('.job-location');
          const isInCanada = jobLocation.textContent.includes('Canada');
          resolve(isInCanada);
        }

        count++;
        if (count > 20) {
          clearInterval(interval);
          reject();
        }
      }, 500);
    });

    return location;
  } catch (error) {
    return false;
  }
}

async function listVouches(tags = []) {
  const url = new URL(`${BASE_API_URL}/vouches/search`);
  const params = new URLSearchParams();
  // convert tags to a comma-separated string and URL encode it
  params.append('tags', tags.join(','));

  // convert types to a comma-separated string and URL encode it
  params.append('types', ['PLAYLIST'].join(','));

  url.search = params.toString();
  const result = await fetch(url, {
    headers: {
      accept: 'application/json',
      'x-api-key': API_KEY,
      'cache-control': 'max-age=0'
    }
  });

  const data = await result.json();
  return data.items || [];
}

async function findMatch(tags) {
  if (!tags.length) {
    return null;
  }

  const vouches = await listVouches(tags);
  return vouches.find((vouch) => {
    return tags.every((tag) => vouch.tags.includes(tag));
  });
}

async function getId(category) {
  const [categoryMatch, fallbackMatch] = await Promise.all([findMatch([category]), findMatch([FALLBACK_TAG])]);

  const match = categoryMatch || fallbackMatch;
  return match?.id;
}

async function getCategory() {
  let count = 0;

  try {
    const jobCategoryText = await new Promise((resolve, reject) => {
      const interval = setInterval(() => {
        const jobInfoElement = document.querySelector('.job-info');

        if (jobInfoElement) {
          clearInterval(interval);
          resolve(jobInfoElement.getAttribute('data-ph-at-job-category-text'));
        }

        count++;
        if (count > 20) {
          clearInterval(interval);
          reject();
        }
      }, 500);
    });

    const category = `${jobCategoryText} (Departments and Roles)`;
    return category;
  } catch (error) {
    return '';
  }
}

(async function () {
  const isInCanada = await checkLocation();

  if (isInCanada) return;

  const $embed = window.document.getElementById('vouch-embed');
  $embed.style.width = '400px';
  $embed.style.aspectRatio = '4/5';
  $embed.style.color = '#333';
  $embed.style.background = '#FFF';
  $embed.style.display = 'flex';
  $embed.style.alignItems = 'center';
  $embed.style.justifyContent = 'center';
  $embed.style.position = 'relative';

  $embed.innerHTML = `<p style="padding: 20px; text-align: center;">Loading...</p>`;

  const category = await getCategory();

  getId(category)
    .then((id) => {
      const vouchId = id || FALLBACK_VOUCH;

      $embed.innerHTML = `
        <vouch-embed-player
          autoplay
          preload="auto"
          controls='["progress","play-large","captions", "volume"]'
          apikey="${API_KEY}"
          vouchid="${vouchId}"
          templateid="${TEMPLATE_ID}"
          style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; aspect-ratio: 0.5625; padding-bottom: 25px;"
         ></vouch-embed-player>
       `;
    })
    .catch(() => {
      $embed.innerHTML = `<p style="padding: 20px; text-align: center;">Something went wrong trying to load the videos.</p>`;
    });
})();
