        flex-direction: column;
        gap: 8px;
    }

    .s-header-menu-sub-nav-link-sm {
        font-size: 16px;
        line-height: 150%;
        font-weight: 400;
        color: #f8f8f8;
    }

    .nav-link-careers {
        margin: 0;
    }

    .nav-link-button {
        display: none;
    }

    .s-header-contact-us {
        display: flex;
        text-transform: uppercase;
        color: #2E53A1;
        font-weight: 500;
        font-size: 14px;
        letter-spacing: 1px;
        border: 1px solid;
        border-radius: 4px;
        padding: 8px 12.5px;
        margin-right: 40px;
        letter-spacing: 2px;
    }

    .s-header-contact-us:hover {
        background-color: #2E53A1;
        color: #f8f8f8;
    }
}

@media(max-width: 1023px) {
    .s-header-on .s-header-logo-wrap {
        display: none;
    }

    .s-header-content {
        justify-content: flex-start;
        height: fit-content;
    }

    .s-header-content {
        padding: 17px 16px;
    }

    .s-header-logo {
        width: 127px;
        height: 34px;
    }

    .s-header-contact-us {
        display: none;
    }

    .s-header-on .s-header-contact-us {
        display: flex;
        margin-right: auto;
    }

    .s-header-menu-on {
        top: 70px;
        left: 0;
        width: 100%;
    }
}


@media(max-width: 1000px) {
    .custom-footer {
        padding: 32px 16px;
    }

    .custom-footer-row-1 {
        flex-direction: column;
    }

    .custom-footer-nav-links-wrap {
        flex-direction: column;
    }

    .custom-footer-nav-links-col,
    .custom-footer-info-wrap {
        gap: 48px;
    }

    .custom-footer-row-2 {
        flex-direction: column;
        gap: 48px;
        align-items: flex-start;
        justify-content: flex-start;
    }
}

@media(max-width: 800px) {
    .job-boards-masthead {
        background-image: none;
    }

    .job-boards-title {
        font-size: 40px;
        line-height: 50px;
    }

    .job-boards-heading {
        margin-top: 56px;
        margin-bottom: 56px;
    }
}

