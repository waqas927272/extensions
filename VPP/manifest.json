{
  "manifest_version": 3,
  "name": "Encore Job Scraper",
  "version": "1.0",
  "description": "Scrape job listings and enrich records for Encore",
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.vetpracticepartners.com/current-openings/*"],
      "js": ["vpp-content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "vpp-content.js",
        "description-scraper.js",
        "greenhouse-description-scraper.js",
        "detail-extractor.js",
        "google-maps-scraper.js",
        "google-search-scraper.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
