{
  "manifest_version": 3,
  "name": "Thrive Job Scraper",
  "version": "1.0",
  "description": "Scrapes Thrive Pet Healthcare jobs from Jobvite recruiter listings.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://careers.thrivepetcare.com/*",
    "https://app.jobvite.com/*",
    "<all_urls>"
  ],
  "icons": {
    "16": "images/logo.png",
    "48": "images/logo.png",
    "128": "images/logo.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/logo.png",
      "48": "images/logo.png",
      "128": "images/logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["google-maps-scraper.js", "google-search-scraper.js", "detail-extractor.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
