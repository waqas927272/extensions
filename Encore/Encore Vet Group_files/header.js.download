let openMenu = document.getElementById('snap-left');
let header = document.querySelector('.header-container');

openMenu.addEventListener('click', function(e) {
    openMenu.classList.toggle('active');
})

const hElements = document.querySelectorAll('.nav-menu');
if(hElements){
    hElements.forEach(element =>{
        element.addEventListener('click',() => {
            if (!element.classList.contains('active-new')){
                for (let i = 0; i < element.length; i++) {
                    element[i].classList.remove('active-new');
                }
            }
            element.classList.toggle('active-new');
        });
    });
}