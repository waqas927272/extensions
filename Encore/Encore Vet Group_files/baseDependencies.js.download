//# sourceMappingURL=moment.min.js.map
'use strict';

var LOGIN_KEY = 'loggedin';
var LOGIN_URL = '/api/jasession';
var LOGIN_BROWSERSESSION_URL = '/api/jasession/browser-close';
var LOGOUT_LINK = '.jibe-logout-button';
var USER_ID_REF = '#link-logout-dropdown';
var JIBE_LOGOUT = document.querySelector('#jibe-logout-container');

function xsession(endpoint) {
  document.cookie = LOGIN_KEY + '=; expires=Thu, 01-Jan-70 00:00:01 GMT;';
  document.cookie = 'session_id' + '=; expires=Thu, 01-Jan-70 00:00:01 GMT;';
  document.cookie = 'sso_user_id3' + '=; expires=Thu, 01-Jan-70 00:00:01 GMT;';
  document.cookie = 'ja_uname' + '=; expires=Thu, 01-Jan-70 00:00:01 GMT;';
  document.cookie = 'loggedin' + '=; expires=Thu, 01-Jan-70 00:00:01 GMT;';
  document.cookie = 'pjuid' + '=; expires=Thu, 01-Jan-70 00:00:01 GMT;';

  if (window.localStorage) {
    try {
      window.localStorage.removeItem('parsedResume');
      window.localStorage.removeItem('percentDone');
    } catch (e) {
      console.error(e);
    }
  }

  if (window.sessionStorage) {
    try {
      window.sessionStorage.removeItem('parsedResume');
      window.sessionStorage.removeItem('percentDone');
      window.sessionStorage.clear();
    } catch (e) {
      console.error(e);
    }
  }

  setTimeout(function () {
    var xhr = new XMLHttpRequest();
    xhr.open("DELETE", endpoint + '?nocache=' + (+new Date()), true);
    if (window.searchConfig && window.searchConfig.logoutRedirectUrl) {
      window.logoutRedirectUrl = window.searchConfig.logoutRedirectUrl;
    }
    xhr.onload = function () {
      var response = xhr.responseText;
      if (xhr.readyState == 4 && xhr.status == "200") {
        setTimeout(function () {
          window.location = window.logoutRedirectUrl;
        });
      } else {
        console.error(response);
      }
    };

    xhr.send(null);
  });
}

$(USER_ID_REF).click(function (evt) {
  evt.preventDefault();
});

$(LOGOUT_LINK).click(function (evt) {
  evt.preventDefault();
  evt.stopPropagation();

  xsession(LOGIN_URL);
});

//dropdown menu fxn
if (JIBE_LOGOUT) {
  document.addEventListener('click', function(e) {
    //if dropdown-menu was clicked, toggle open
    if (e.target.id === 'link-logout-dropdown') {
      JIBE_LOGOUT.classList.toggle('open-menu');
    }
    //if something else was clicked, close
    else {
      JIBE_LOGOUT.classList.remove('open-menu');
    }
  });
}

if (window.logoutRedirectOnTimeout) {
  var checkCookie = function () {

    var lastCookie = document.cookie; // 'static' memory between function calls

    return function () {

      var currentCookie = document.cookie;

      if (currentCookie !== lastCookie) {
        if (lastCookie.indexOf('sso_user_id3') > -1 && currentCookie.indexOf('sso_user_id3') === -1) {
          xsession(LOGIN_URL)
        }

        lastCookie = currentCookie; // store latest cookie
      }
    };
  }();

  window.setInterval(checkCookie, 30000); // run every 30 s
}

'use strict';

var url;

var TRACK_IF_API = '/api/trackif/send';
var TRACK_IF_EMAIL = '#jibe-trackif-email';
var TRACK_IF_ERR_EMAIL_TEXT = '#jibe-trackif-error-noemail';
var TRACK_IF_ERR_NO_CAPTCHA = '#jibe-trackif-error-nocaptcha'
var TRACK_IF_ERR_PROCESS_TEXT = '#jibe-trackif-error-process';
var TRACK_IF_SUCCESS_PROCESS_TEXT = '#jibe-trackif-success-process';
var TRACK_IF_FORM = '#job-alerts-form';

$(TRACK_IF_FORM).submit(function (evt) {
  evt.preventDefault();

  ///on request hide all messages
  $(TRACK_IF_ERR_EMAIL_TEXT).addClass('hidden');
  $(TRACK_IF_ERR_PROCESS_TEXT).addClass('hidden');
  $(TRACK_IF_ERR_NO_CAPTCHA).addClass('hidden');
  $(TRACK_IF_SUCCESS_PROCESS_TEXT).addClass('hidden');

  function showMessage(id) {
    if ($(id).hasClass('hidden')) {
      $(id).removeClass('hidden');
    }
    else {
      $(id).addClass('hidden');
    }
  }

  //Configure URL
  url = window.location.href;

  if (window.jobAlertConfiguration) {
    var host = window.location.protocol + '//' + window.location.host + '/jobs';
    url = host + '?categories=' + encodeURI(window.jobAlertConfiguration.job_categories) + '&keywords=' + encodeURI(window.jobAlertConfiguration.job_title) + '&location=' + encodeURI(window.jobAlertConfiguration.job_location);
  }

  var email = $(TRACK_IF_EMAIL).val();
  var emailRegex = new RegExp('.+\@.+\..+');

  if (!email || email === '' || !emailRegex.test(email)) {
    return showMessage(TRACK_IF_ERR_EMAIL_TEXT);
  }

  setTimeout(function () {
    var data = $(TRACK_IF_FORM).serialize() + '&url=' + url;

    $.ajax({
      url: TRACK_IF_API,
      type: 'POST',
      data: data,
      success: function (response) {

        if (response.status === 'success') {
          //if jobAlertsModal is open, close it          
          if ($('#jobAlertsModal.show')) {
            $('#jobAlertsModal.show').click();
          }

          $(TRACK_IF_EMAIL).val('');
          showMessage(TRACK_IF_SUCCESS_PROCESS_TEXT);
        }
        else {
          showMessage(TRACK_IF_ERR_PROCESS_TEXT);
        }
      },

      error: function (jqXHR, textStatus, errorThrown) {
        console.log('Trackif Error', jqXHR, textStatus, errorThrown);

        if (jqXHR.responseText && jqXHR.responseText.indexOf('Captcha not validated') > -1) {
          showMessage(TRACK_IF_ERR_NO_CAPTCHA);
        } else {
          showMessage(TRACK_IF_ERR_PROCESS_TEXT);
        }
      }
    });

  });

});

'use strict';

var APPLY_ROUTE = '/apply/';
var JOB_APPLY_ROUTE = '/job-apply/';

function isLocalStorageNameSupported () {
  var testKey = 'test', storage = window.sessionStorage;
  try {
    storage.setItem(testKey, '1');
    storage.removeItem(testKey);
    return true;
  }
  catch (error) {
    return false;
  }
}

function onProfileData (profileData) {

  var pathParams = window.location.pathname.split('/');
  var slug;

  if (pathParams && pathParams[2]) {
    slug = pathParams[2];
  }

  if (profileData && profileData.contentBlocking) {
    return window.location = JOB_APPLY_ROUTE + slug + '/error?reason=content_blocking';
  }

  if (profileData && profileData.timeout) {
    return window.location = JOB_APPLY_ROUTE + slug + '/error?reason=redirect_failed';
  }

  if (slug && profileData) {
    $.ajax({
      url: '/api/users/create?slug=' + slug,
      type: 'POST',
      dataType: 'json',
      contentType: "application/json",
      data: JSON.stringify(profileData),
      success: function (response) {
        if (isLocalStorageNameSupported()) {
          window.localStorage.parsedResume = JSON.stringify(response);
        }
        window.location = APPLY_ROUTE + slug + '/';
      },
      error: function (jqXHR, textStatus, errorThrown) {
        console.log('Job-Apply Error', jqXHR, textStatus, errorThrown);
        return window.location = JOB_APPLY_ROUTE + slug + '/error?reason=user_create_error';
      }
    });
  } else {
    console.log('Job-Apply Error');
    return window.location = JOB_APPLY_ROUTE + slug + '/error?reason=api_error';
  }
}
