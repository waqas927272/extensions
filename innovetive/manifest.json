{
  "manifest_version": 3,
  "name": "Innovetive Petcare Job Scraper",
  "version": "1.7",
  "description": "Scrapes job data from the Innovetive Petcare careers page and saves it.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://innovetivepetcare.pinpointhq.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["description-scraper.js", "detail-extractor.js", "google-maps-scraper.js", "google-search-scraper.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
