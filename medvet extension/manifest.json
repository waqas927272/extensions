{
  "manifest_version": 3,
  "name": "Job Scraper",
  "version": "1.0",
  "description": "Scrapes job listings from the current page.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
