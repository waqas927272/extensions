{
  "manifest_version": 3,
  "name": "Mission Pet Health Job Scraper",
  "version": "1.0",
  "description": "Scrape job listings from Mission Pet Health careers page",
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://missionpethealth.avature.net/careersmarketplace/SearchJobs*",
        "https://missionpethealth.avature.net/agency/OpenPositions*"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["description-scraper.js", "google-maps-scraper.js"],
      "matches": ["<all_urls>"]
    }
  ]
}