{
  "manifest_version": 3,
  "name": "Mission Pet Health Job Scraper",
  "version": "1.7",
  "description": "Scrapes job data from the current page and saves it.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://missionpethealth.avature.net/careersmarketplace/SearchJobs*",
        "https://missionpethealth.avature.net/agency/OpenPositions*"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["description-scraper.js", "detail-extractor.js", "google-maps-scraper.js", "google-search-scraper.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
