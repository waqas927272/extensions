    $('.team-single-gallery').slick({
        arrows: true,
        infinite: true,
        speed: 300,
        slidesToShow: 1,
        adaptiveHeight: true,
        autoplay: true,
        dots: true
    });

    $('.denovo-slider').slick({
        arrows: true,
        infinite: true,
        speed: 300,
        slidesToShow: 1,
        adaptiveHeight: true,
    });

    $('.testimonials-slider').slick({
        adaptiveHeight: true
    });


    $(".mobile-menu-trigger").on('click', function (event) {
        event.preventDefault();
        $("header").toggleClass('mobile-menu-active');
    });
    //OUR CULTURE SLIDER
    $('.our-culture-slider').slick({
        arrows: true,
        infinite: true,
        speed: 300,
        slidesToShow: 1,
        adaptiveHeight: true,
        prevArrow: '<button type="button" class="slick-prev"><svg xmlns="http://www.w3.org/2000/svg" width="11" height="16" viewBox="0 0 11 16" fill="none">\n' +
            '<path d="M0.343751 6.98486L6.98438 0.344239C7.44336 -0.114745 8.18555 -0.114745 8.63965 0.344239L9.74317 1.44775C10.2021 1.90674 10.2021 2.64893 9.74317 3.10303L5.03613 7.81006L9.74316 12.5171C10.2021 12.9761 10.2021 13.7183 9.74316 14.1724L8.64453 15.2856C8.18555 15.7446 7.44336 15.7446 6.98926 15.2856L0.348633 8.64502C-0.115234 8.18603 -0.115234 7.44385 0.343751 6.98486Z" fill="#CC790E"/>\n' +
            '</svg></button>',
        nextArrow:
            '<button type="button" class="slick-next"><svg xmlns="http://www.w3.org/2000/svg" width="11" height="16" viewBox="0 0 11 16" fill="none">\n' +
            '<path d="M9.74365 8.64502L3.10303 15.2856C2.64404 15.7446 1.90186 15.7446 1.44775 15.2856L0.344238 14.1821C-0.114746 13.7231 -0.114746 12.981 0.344238 12.5269L5.05127 7.81982L0.344238 3.11279C-0.114746 2.65381 -0.114746 1.91162 0.344238 1.45752L1.44287 0.344238C1.90186 -0.114746 2.64404 -0.114746 3.09814 0.344238L9.73877 6.98486C10.2026 7.44385 10.2026 8.18604 9.74365 8.64502Z" fill="#CC790E"/>\n' +
            '</svg></button>',
    });

    var $collapses = $('.collapse');
    var $firstCollapse = $collapses.eq(0);
    var $list = $('.open-positions-list-item');
    var $firstCollapseButton = $list.eq(0).find('button').eq(0);

    var $activeButton = $firstCollapseButton;

    $firstCollapse.addClass('show');
    $firstCollapseButton.addClass('active');

    $('[data-toggle="collapse"]').on('click', function () {
        var target = $(this).data('target');
        var $target = $(target);
        if ($target.hasClass('show')) {
            return;
        }
        var $clickedButton = $(this);
        if ($activeButton[0] !== $clickedButton[0]) {
            $activeButton.removeClass('active');
        }
        $activeButton = $clickedButton;

        $collapses.not($target).removeClass('show');
        $target.addClass('show');
        $(this).addClass('active');
    });


    const block = document.querySelector('.dev-navigation-list');

    if (block) {
        window.addEventListener('scroll', function () {
            if (window.scrollY > 100) {
                block.style.backgroundColor = 'white';
            } else {
                block.style.backgroundColor = 'transparent';
            }
        });
    }
    //TEAM LEADERSHIP
    const teamLeadershipStatic = document.querySelectorAll('.team_member-img-container');
    const fadeInDelay = 1300;
    let fadeInTimer, fadeOutTimer;

    teamLeadershipStatic.forEach((staticElement, index) => {
        const teamLeadershipAnim = staticElement.querySelectorAll('.team_area-img--anim');
        clearInterval(fadeInTimer);
        clearTimeout(fadeOutTimer);

        const fadeInAnim = function () {
            if (index < teamLeadershipAnim.length) {
                const animElement = teamLeadershipAnim[index];
                animElement.style.opacity = '1';
                index++;
                fadeInTimer = setTimeout(fadeInAnim, fadeInDelay);
            } else {
                resetOpacity();
                index = 0;
                fadeInTimer = setTimeout(fadeInAnim, fadeInDelay);
            }
        };

        const fadeOutAnim = function () {
            teamLeadershipAnim.forEach(animElement => {
                animElement.style.opacity = 0;
            });
        };

        fadeOutAnim(); // Зробимо всі зображення невидимими в початковому стані

        staticElement.addEventListener('mouseenter', function () {
            fadeOutAnim(); // Зробимо всі зображення невидимими при наведенні миші
            clearInterval(fadeInTimer);
            clearTimeout(fadeOutTimer);
            fadeInAnim();
        });

        staticElement.addEventListener('mouseleave', () => {
            clearTimeout(fadeInTimer);
            clearInterval(fadeOutTimer);
            fadeOutAnim();
        });
    });

    function resetOpacity() {
        const teamLeadershipAnim = document.querySelectorAll('.team_area-img--anim');
        teamLeadershipAnim.forEach(animElement => {
            animElement.style.opacity = 0;
        });
    }




});



if (navigator.userAgent.indexOf('Safari') !== -1 && navigator.userAgent.indexOf('Chrome') === -1) {
    document.documentElement.classList.add('safari');
}