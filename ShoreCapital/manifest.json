{
  "manifest_version": 3,
  "name": "Shore Capital Job Scraper",
  "version": "1.0",
  "description": "Scrapes job listings from Shore Capital job board (jobs.shorecp.com).",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://jobs.shorecp.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["description-scraper.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
