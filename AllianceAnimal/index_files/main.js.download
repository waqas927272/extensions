(function ($) {
  window.main = {
    observers: [],
    init: function () {
      setTimeout(() => {
        this.filteringPost();
        this.partnersSlider(2000);

        this.fixTestimonialsHeight(1700);
        this.fixMosaciLayout(1500);
        this.imgToSvg(null);
        this.animateImages();
        this.lottie_animation();
        this.removableContainer();
        this.pdfContent();
        this.uniquePrograms();
        this.coreValues();
        this.testimonialsArrows(true, 1700);
        this.fixContentBoxHeight();
        this.listEqualHeight();
        this.renameFormButton();
        this.chompingSlider();
        this.teamMembersHover();

        main.jobsListing();

        this.observer(".swiper-slide", main.postCardsEqualHeight);

        this.observer(".off-canvas-content", main.fixMenuPosition);

      }, 200);

      /* Hide Practices post on first load */
      if ($(".mapsvg").length > 0) {
        $grid = $(".postFiltering .fusion-grid").isotope({
          resizable: false,
          layoutMode: "fitRows",
          itemSelector: ".fusion-post-cards-grid-column",
        });

        $grid.isotope({
          filter: "-",
        });
      }

      /* On resize */
      var rtime;
      var timeout = false;
      var delta = 200;
      $(window).resize(function () {
        rtime = new Date();
        if (timeout === false) {
          timeout = true;
          setTimeout(resizeend, delta);
        }
      });

      function resizeend() {
        if (new Date() - rtime < delta) {
          setTimeout(resizeend, delta);
        } else {
          timeout = false;
          main.partnersSlider(0);

          if ($(".fusion-post-cards.flexslider").length > 0) {
            if ($(window).width() < 1024) {
              $(
                ".fusion-post-cards.flexslider ul li > .fusion-column-wrapper .title-heading-tag"
              ).height("auto");
            }
          }

          if ($(window).width() > 1024) {
            jQuery(".dtr-control").removeClass("dtr-control");
            if ($(".reviews").length > 0) {
              $(".reviews .review").height("auto");
            }
            if ($(".paw_icon").length > 0) {
              main.listEqualHeightAction();
            }
          } else {
            $(".paw_icon").css({
              height: "auto",
            });
          }

          //$(".post-card.swiper-slide") exists
          if ($(".post-card.swiper-slide").length > 0) {
            main.postCardsEqualHeight();
          }
        }
      }
    },
    observer: function (search, func) {
      // Select the entire DOM for observing:
      const target = document.querySelector("body");

      // Create a new observer instance:
      main.observers[search] = new MutationObserver(function () {
        if (document.querySelector(search)) {
          setTimeout(() => {
            if (func !== undefined) {
              func();
            }
          }, 1000);
          // Do something with new div element
          main.observers[search].disconnect();
        }
      });

      // Set configuration object:
      const config = {
        childList: true,
      };

      // Start the observer
      main.observers[search].observe(target, config);
    },
    postCardsEqualHeight: function () {
      //set max height to auto
      $(".post-card.swiper-slide > .fusion-column-wrapper").height("auto");

      //get max height from all cards
      var maxHeight = 0;
      $(".post-card.swiper-slide > .fusion-column-wrapper").each(function (index, element) {
        var _tmp = $(this).height();
        if (_tmp > maxHeight) {
          maxHeight = _tmp;
        }
      });

      //set max height to all cards
      $(".post-card.swiper-slide > .fusion-column-wrapper").height(maxHeight);

    },
    cleanText: function (_tmp, lowerCase) {
      if (lowerCase === undefined) {
        lowerCase = true;
      }
      _tmp = _tmp.replace(new RegExp("<sup>™</sup>", "gm"), "");
      _tmp = _tmp.replace(new RegExp("#", "gm"), "");
      _tmp = _tmp.replace(new RegExp("&", "gm"), "");
      _tmp = _tmp.replace(new RegExp("™", "gm"), "");
      _tmp = _tmp.replace(new RegExp("<sup>®</sup>", "gm"), "");
      _tmp = _tmp.replace(new RegExp("®", "gm"), "");
      _tmp = _tmp.replace(new RegExp("&amp;", "gm"), "&");
      _tmp = _tmp.replace(new RegExp("-", "gm"), "");
      _tmp = _tmp.replace(new RegExp("–", "gm"), "");
      _tmp = _tmp.replace(new RegExp(" ", "gm"), "");
      if (lowerCase) {
        _tmp = _tmp.toLowerCase();
      }

      return _tmp;
    },
    eqipmentHeight: function () {
      var item = $(".fusion-post-cards-grid-column"),
        maxHeight = 0;

      item.each(function (index, el) {
        var itemHeight = parseInt($(this).height());
        itemHeight > maxHeight ? (maxHeight = itemHeight) : false;
      });

      item.height(maxHeight);
    },
    filteringPost: function () {
      if ($(".filterButton").length > 0) {
        $grid = $(".postFiltering .fusion-grid").isotope({
          resizable: false,
          layoutMode: "fitRows",
          itemSelector: ".fusion-post-cards-grid-column",
          stagger: 30,
          percentPosition: true,
        });

        main.eqipmentHeight();
        $grid.isotope({
          filter: "*",
        });

        /* Filter by Brand menu items */

        $(".filterButton").on("click", function (event) {
          event.preventDefault();

          $(".filterButton").removeClass("active");
          $(this).addClass("active");

          var options = new Array();
          $grid.isotope({
            filter: "*",
          });

          var _tmp = $(this).find("a").attr("href");
          _tmp = main.cleanText(_tmp);

          if (_tmp != "all") {
            options.push(_tmp);

            $grid.isotope({
              filter: function () {
                // _this_ is the item element. Get text of element's
                var _filteringText = $.trim(
                  $(this).find(".filterCategory h4").html()
                );
                _filteringText = main.cleanText(_filteringText);
                _filteringText = _filteringText.split(",");

                const intersection = options.filter((element) =>
                  _filteringText.includes(element)
                );
                // return true to show, false to hide
                return !!intersection.length > 0;
              },
              sortBy: ["category", "name"],
            });
            $(
              "nav.industryFilteringControl .avada-menu-mobile-menu-trigger"
            ).trigger("click");
          }
        });
      }
    },
    filterPractices: function () {
      /* This function is loaded on the map settings */
      if ($(".mapsvg-wrap-all").length > 0) {
        $grid = $(".postFiltering .fusion-grid").isotope({
          resizable: true,
          /*  layoutMode: 'masonry', */
          itemSelector: ".fusion-post-cards-grid-column",
          stagger: 30,
          percentPosition: true,
          layoutMode: "fitRows",
        });

        /* Trigger Regions click on marker click */
        $(".mapsvg-marker").on("click touchend", function () {
          var title = $(this).attr("alt");
          var id = $("path[title='" + title + "']").attr("id");

          $("#" + id).click();
        });

        /* Filter by Brand menu items */

        $(".mapsvg path").on("click touchend", function (event) {
          $(".mapsvg-marker").removeClass("active");

          var title = $(this).attr("title");
          jQuery(".mapsvg-marker[alt='" + title + "']").addClass("active");

          $(".mapsvg-region-active").removeClass("mapsvg-region-active").css({
            fill: "rgb(227, 227, 227)",
          });
          $(this).addClass("mapsvg-region-active mapsvg-region-hover").css({
            fill: "#5597CD",
          });

          var options = new Array();
          $grid.isotope({
            filter: "-",
          });

          var _tmp = $(this).attr("id").replace(new RegExp("US-", "gm"), "");
          _tmp = main.cleanText(_tmp, true);
          options.push(_tmp);

          $grid.isotope({
            filter: function () {
              // _this_ is the item element. Get text of element's
              var _filteringText = $.trim($(this).find(".filterState").text());
              _filteringText = main.cleanText(_filteringText);
              _filteringText = _filteringText.split(",")[1];

              const intersection = options.filter((element) =>
                _filteringText.includes(element)
              );
              // return true to show, false to hide
              return !!intersection.length > 0;
            },
            sortBy: ["category", "name"],
          });

          $(
            "nav.industryFilteringControl .avada-menu-mobile-menu-trigger"
          ).trigger("click");

          $grid.isotope("bindResize");
          jQuery("html, body").animate({
              scrollTop: jQuery(".postFiltering").offset().top - 120,
            },
            1000
          );
        });
      }
    },
    partnersSlider: function (_await) {
      if ($(".partners_slider").length > 0) {
        document.documentElement.style.setProperty(
          "--partners_slider_item",
          "19vw"
        );
        setTimeout(() => {
          var sliderWidth = $(".partners_slider:nth-child(1)").width();
          document.documentElement.style.setProperty(
            "--partners_slider_item",
            sliderWidth + "px"
          );
        }, _await);
      }
    },
    fixTestimonialsHeight: function (_await) {
      if ($(".fusion-post-cards.flexslider").length > 0) {
        if ($(window).width() > 1024) {
          setTimeout(() => {
            /* Fix Equal Heigth */
            var maxHeight = 0;
            $.each(
              $(
                ".fusion-post-cards.flexslider ul li > .fusion-column-wrapper .title-heading-tag"
              ),
              function (i, e) {
                var _height = $(this).height();

                if (_height > maxHeight) {
                  maxHeight = _height;
                }
              }
            );

            $(
              ".fusion-post-cards.flexslider ul li > .fusion-column-wrapper .title-heading-tag"
            ).height(maxHeight);
          }, _await);
        }
      }
    },
    fixMosaciLayout: function (_await) {
      if ($(".MosaicLayout").length > 0) {
        var grid = $(".MosaicLayout ul").isotope({
          // main isotope options
          itemSelector: ".fusion-layout-column",
          // set layoutMode
          layoutMode: "masonry",
        });
      }
    },
    jobsListing: function () {
      if ($("#jobsListingContainer").length > 0) {
        $.fn.DataTable.ext.pager.numbers_length = 5;

        var table = $("#jobsListingContainer").DataTable({
          initComplete: function (settings, json) {
            $("#jobsListingContainer").fadeIn();
            $("#jobsListing #loading").removeClass("active");
          },
          lengthChange: false,
          ordering: false,
          responsive: true,
          info: false,
          drawCallback: function (settings) {
            setTimeout(() => {
              if ($(window).width() > 1024) {
                jQuery(".dt-hasChild.shown").removeClass("dt-hasChild shown");
                jQuery("tbody tr.no-padding").hide().remove();
              }
            }, 10);
          },
          columnDefs: [{
              targets: [0],
              visible: false,
              searchable: false,
            },
            {
              targets: [1],
              visible: false,
            },
            {
              targets: [2],
              width: "30%",
              class: "all",
              /* class: "desktop details-control", */
            },
            {
              targets: [3],
              class: "all",
              width: "30%",
              render: function (data, type, row, meta) {
                if (type === "display") {
                   var _fixedText = $("<div/>").html(row[0]).text();
                  data =
                    '<a href="https://www.smartrecruiters.com/AllianceAnimalHealth/' + _fixedText + '" target="_blank">' + data + "</a>";
                }
                return data;
              },
            },
            {
              targets: [5],
              visible: false,
            },
            {
              targets: [6],
              class: "desktop",
            },
            {
              targets: [7],
              class: "desktop",
            },
          ],
          fixedColumns: true,
        });

        if ($(window).width() > 1024) {
          jQuery(".dtr-control").removeClass("dtr-control");
        }

        /* Responsive table */
        table.on("responsive-resize", function (e, datatable, columns) {
          var count = columns.reduce(function (a, b) {
            return b === false ? a + 1 : a;
          }, 0);

          $("#jobsListing table tr").removeClass("parent shown");
          //$(".dtr-control").removeClass("dtr-control");

          table
            .rows()
            .eq(0)
            .each(function (idx) {
              var row = table.row(idx);

              if (row.child.isShown()) {
                row.child.close();
              }
            });

          $.fn.DataTable.ext.pager.numbers_length = 3;
        });

        $("#jobsListingContainer").on(
          "click",
          ".details-control",
          function (e) {
            //e.preventDefault();
            //$(".dtr-control").removeClass("dtr-control");
            var tr = $(this).closest("tr");
            var row = table.row(tr);

            if ($(tr).hasClass("shown")) {
              // This row is already open - close it
              $(tr).removeClass("shown");
              $("div.slider", row.child()).slideUp(function () {
                row.child.hide();
              });
            } else {
              // Open this row
              row.child(main.format(row.data()), "no-padding").show();
              tr.addClass("shown");

              $("div.slider", row.child()).slideDown();
            }

            $(tr).removeClass("current");
          }
        );

        /* Filter by choose */
        $("#hospitalName").on("change", function () {
          var searchTerm = $(this).val();
          if (searchTerm != "") {
            var regex = "^" + searchTerm + "$";
            table
              .columns($(this).attr("_column"))
              .search(regex, true, false)
              .draw();
          } else {
            table.columns($(this).attr("_column")).search("").draw();
          }
        });

        $("#jobTitle").on("change", function () {
          var searchTerm = $(this).val();
          if (searchTerm != "") {
            var regex = "^" + searchTerm + "$";
            table
              .columns($(this).attr("_column"))
              .search(regex, true, false)
              .draw();
          } else {
            table.columns($(this).attr("_column")).search("").draw();
          }
        });

        $("#hospitalType").on("change", function () {
          var searchTerm = $(this).val().toLowerCase();
          //remove + sign
          searchTerm = searchTerm.replace("+", "\\+");

          if (searchTerm != "") {
            var regex = "^" + searchTerm + "$";
            table
              .columns($(this).attr("_column"))
              .search(regex, true, false)
              .draw();
          } else {
            table.columns($(this).attr("_column")).search("").draw();
          }
        });

        $("#jobType").on("change", function () {
          var searchTerm = $(this).find("option:selected").text().toLowerCase();

          //remove + sign
          searchTerm = searchTerm.replace("+", "\\+");

          if (searchTerm != "" && searchTerm != "all types") {
            var regex = "^" + searchTerm + "$";
            table
              .columns($(this).attr("_column"))
              .search(regex, true, false)
              .draw();
          } else {
            table.columns($(this).attr("_column")).search("").draw();
          }
        });

        $("#jobsSubtype").on("change", function () {
          var searchTerm = $(this).val();
          var column = 0;
          table.columns(5).search("").draw();
          table.columns(6).search("").draw();
          if (isNaN(searchTerm)) {
            column = $(this).attr("_column");
          } else {
            column = $(this).attr("_column") - 1;
          }

          if (searchTerm != "") {
            var regex = "^" + searchTerm + "$";
            table.columns(column).search(regex, true, false).draw();
          } else {
            table.columns(5).search("");
            table.columns(6).search("").draw();
          }
        });

        $("#jobLocation").on("change", function () {
          var searchTerm = $(this).val().toLowerCase();
          if (searchTerm != "") {
            var regex =
              ", " +
              searchTerm +
              "$|" +
              ", " +
              $("#jobLocation option:selected").html() +
              "$";
            table
              .columns($(this).attr("_column"))
              .search(regex, true, false)
              .draw();
          } else {
            table.columns($(this).attr("_column")).search("").draw();
          }
        });
      }
    },
    /* Formatting function for row details - modify as you need */
    format: function (d) {
      // `d` is the original data object for the row
      return (
        '<div class="slider">' +
        '<table cellpadding="5" cellspacing="0" border="0" style="padding-left:50px;">' +
        "<tr>" +
        "<td>Organization:</td>" +
        "<td>" +
        d[3] +
        "</td>" +
        "</tr>" +
        "<tr>" +
        "<td>Location:</td>" +
        "<td>" +
        d[4] +
        "</td>" +
        "</tr>" +
        "<tr>" +
        "</table>" +
        "</div>"
      );
    },
    animateImages: function () {
      //Scroll Animation
      if ($(".animate_image").length > 0) {
        // this function runs every time you are scrolling

        $(".animate_image").each(function () {
          var el = $(this);
          $(window).scroll(function () {
            var position = $(el).get(0).getBoundingClientRect();
            var viewPort = document.documentElement.clientHeight;

            if (position.top > 0 && position.top < viewPort) {
              //var _imageSize = getComputedStyle(document.documentElement).getPropertyValue("--animate_image_scroll").replace("px", "");
              var _imageSize = "130";
              document.documentElement.style.setProperty(
                "--animate_image_scroll",
                _imageSize + "px"
              );

              $(el).addClass("animating");
              var currentScroll = position.top;
              var _position = (100 - (100 * currentScroll) / viewPort) * 1.5;

              var _newPosition = -Math.abs(_imageSize) -
                (-Math.abs(_imageSize) / 100) * _position;

              if (_newPosition > 0) {
                _newPosition = 0;
              }

              if ($(el).hasClass("left")) {
                $(el).css({
                  left: _newPosition,
                });
              } else {
                _newPosition = Math.abs(_imageSize) - Math.abs(_newPosition);
                $(el).css({
                  right: "calc(-100vw + " + _newPosition + "px)",
                });
              }

              //document.querySelector(':root').style.setProperty('--animate_image_scroll', _newPosition + "px");
            } else {
              $(el).removeClass("animating");
            }
          });
        });
      }
    },
    imgToSvg: function (callback) {
      $(".svg img").each(function (index, image) {
        // element == this
        fetch(image.src)
          .then((res) => res.text())
          .then((data) => {
            const parser = new DOMParser();
            const svg = parser
              .parseFromString(data, "image/svg+xml")
              .querySelector("svg");

            if (svg != null) {
              if (image.id) svg.id = image.id;
              if (image.className) svg.classList = image.classList;

              //image.parentNode.replaceChild(svg, image);
              $(image).replaceWith(svg);
            }
          })
          .then(callback);
      });

      /*  images.forEach(image => {

                 fetch(image.src)
                     .then(res => res.text())
                     .then(data => {
                         const parser = new DOMParser();
                         const svg = parser.parseFromString(data, 'image/svg+xml').querySelector('svg');

                         if (svg != null) {
                             if (image.id) svg.id = image.id;
                             if (image.className) svg.classList = image.classList;

                             image.parentNode.replaceChild(svg, image);
                         }
                     })
                     .then(callback)

             }); */
    },
    lottie_animation: function () {
      if ($(".lottie_animation")) {
        $(".lottie_animation").each(function (index, element) {
          if ($(this).hasClass("birds")) {
            $(this).prepend(
              '<lottie-player src="' +
              location.origin +
              '/wp-content/uploads/2021/11/Birds.json"  background="transparent"  speed="0.5"   loop autoplay></lottie-player>'
            );
          } else if ($(this).hasClass("fish")) {
            $(this).prepend(
              '<lottie-player src="' +
              location.origin +
              '/wp-content/uploads/2021/11/Fish.json"  background="transparent"  speed="1"    loop autoplay></lottie-player>'
            );
          } else if ($(this).hasClass("cat")) {
            $(this).append(
              '<lottie-player src="' +
              location.origin +
              '/wp-content/uploads/2021/11/Cat.json"  background="transparent"  speed="1"    loop autoplay></lottie-player>'
            );
          }
        });
      }
    },
    removableContainer: function () {
      if ($(".removableContainer").length > 0) {
        $(".removableContainer .close").on("click", function () {
          $(".removableContainer").remove();
        });
      }
    },
    pdfContent: function () {
      if ($(".pdf_content_link").length > 0) {
        $(".pdf_content_link a, .pdf_content .close").on("click", function (e) {
          e.preventDefault();

          $(".pdf_content_link").toggleClass("active");
          $(".pdf_content").toggleClass("active");
        });
      }
    },
    uniquePrograms: function () {
      if ($(".alliance_logos").length > 0) {
        var _siteWidth = $(window).width();

        if (_siteWidth < 661) {
          $(".alliance_logos").removeClass("active");
          $(".alliance_content").removeClass("active");
        }

        var _maxHeight = 0;
        $(".alliance_content.benefits.active .fusion-title.title").each(
          function (index, element) {
            if ($(this).height() > _maxHeight) {
              _maxHeight = $(this).height();
            }
          }
        );
        $(".alliance_content.benefits.active .fusion-title.title").height(
          _maxHeight
        );

        $(".alliance_logos:not(.on_hover)").on("click", function () {
          main.uniqueProgramsActions(this);

          if (_siteWidth < 661) {
            jQuery("html, body").animate({
                scrollTop: jQuery(".alliance_content:visible").offset().top,
              },
              1000
            );
          }
        });

        $(".alliance_logos.on_hover").on("mouseenter", function () {
          main.uniqueProgramsActions(this);
        });
      }
    },
    uniqueProgramsActions: function (_this) {
      var _prev = $(".alliance_logos.prev").index();
      if (!$(_this).hasClass("active")) {
        $(".alliance_logos").removeClass("active left right");
        $(".alliance_content").removeClass("active");

        var _clases = $(_this).attr("class").split(" ");
        $.each(_clases, function (i, v) {
          if (v.includes("type_")) {
            var _tmp = v.split("_");
            $(".alliance_content." + _tmp[1]).addClass("active");
          }
        });

        $(".alliance_logos").removeClass("prev");
        $(_this).addClass("active");
        if ($(window).width() > 1024) {
          if (_prev > $(_this).index()) {
            $(_this).addClass("prev  left");
          } else {
            $(_this).addClass("prev  right");
          }
        }

        /* Fix titles size */
        var _maxHeight = 0;
        $(".alliance_content.benefits.active .fusion-title.title").each(
          function (index, element) {
            if ($(this).height() > _maxHeight) {
              _maxHeight = $(this).height();
            }
          }
        );
        $(".alliance_content.benefits.active .fusion-title.title").height(
          _maxHeight
        );
      }
    },
    coreValues: function () {
      if ($(".core_values").length > 0) {
        $(".core_values .fusion-title.title").on("click", function () {
          var _value = $(this)
            .find(".fusion-responsive-typography-calculated")
            .text();

          $(".core_values .fusion-title.title.active").removeClass("active");
          $(".core_values_content").removeClass("active");

          $(this).addClass("active");
          $(".core_values_content." + _value).addClass("active");
        });
      }
    },
    testimonialsArrows: function (_fix, _await) {
      if ($(".fusion-testimonials").length > 0) {
        var html = `<ul class="flex-direction-nav">
                    <li class="flex-nav-prev">
                        <a class="flex-prev" href="#"></a>
                    </li>
                    <li class="flex-nav-next">
                        <a class="flex-next" href="#"></a>
                    </li>
                </ul>`;

        $(".fusion-testimonials").append(html);

        $(".flex-direction-nav a").on("click", function (e) {
          e.preventDefault();
          var _direction = $(this).attr("class");
          var _max = $(".testimonial-pagination a").length;
          var _current = $(".testimonial-pagination .activeSlide").index();

          if ("flex-prev" == _direction) {
            var _prev = _current - 1;
            if (_prev >= 0 && _current > 0) {
              $(".testimonial-pagination a").eq(_prev).click();
            } else {
              $(".testimonial-pagination a")
                .eq(_max - 1)
                .click();
            }
          }

          if ("flex-next" == _direction) {
            var _next = _current + 1;
            if (_next < _max) {
              $(".testimonial-pagination a").eq(_next).click();
            } else {
              $(".testimonial-pagination a").eq(0).click();
            }
          }
        });
        $(
          $(
            ".comments_slider .fusion-layout-column:nth-child(2) .fusion-column-wrapper > div:not(.fusion-testimonials)"
          )[0]
        ).addClass("active");
        $(
          ".comments_slider .fusion-layout-column:nth-child(1) .fusion-column-wrapper>div:nth-child(1)"
        ).addClass("active");

        $(".testimonial-pagination a").on("click", function () {
          setTimeout(() => {
            $(
              ".comments_slider .fusion-layout-column:nth-child(2) .fusion-column-wrapper > div:not(.fusion-testimonials)"
            ).removeClass("active");
            $(
              ".comments_slider .fusion-layout-column:nth-child(1) .fusion-column-wrapper>div"
            ).removeClass("active");

            //Active comment
            var _activeTestimonial = $(
              ".active-testimonial .company-name"
            ).text();
            _activeTestimonial = main.cleanText(_activeTestimonial);

            $(
                ".comments_slider .fusion-layout-column:nth-child(2) .fusion-column-wrapper .fusion-button." +
                _activeTestimonial
              )
              .parent()
              .addClass("active");
            $(
                ".comments_slider .fusion-layout-column:nth-child(1) .fusion-column-wrapper .fusion-imageframe." +
                _activeTestimonial
              )
              .parent()
              .addClass("active");
          }, 100);
        });

        /* Fix height */

        if (_fix) {
          /* Fix Equal Heigth */
          var maxHeight = 0;
          $.each($(".reviews blockquote"), function (i, e) {
            var _height = $(this).height();

            if (_height > maxHeight) {
              maxHeight = _height;
            }
          });

          $(".reviews blockquote").height(maxHeight);
        }
      }
    },
    fixContentBoxHeight: function () {
      if ($(".content-box-column.content-box-column").length > 0) {
        $(".content-box-column.content-box-column").on("click", function () {
          $(".content-box-column.content-box-column").removeClass("active");
          $(this).addClass("active");
        });
      }
    },
    listEqualHeight: function () {
      if ($(".paw_icon").length > 0) {
        main.listEqualHeightAction();
      }
    },
    listEqualHeightAction: function () {
      var _maxHeight = 0;
      $(".paw_icon").each(function (index, element) {
        var _tmp = $(this).outerHeight(true);
        if (_tmp > _maxHeight) {
          _maxHeight = _tmp;
        }
      });
      $(".paw_icon").css({
        height: _maxHeight,
      });
    },
    renameFormButton: function () {
      if ($("#gform_submit_button_1").length > 0) {
        /* How we work */
        if ($("body").hasClass("page-id-10")) {
          $("#gform_submit_button_1").val("Submit");
        }
      }
    },
    chompingSlider: function () {
      if ($(".chomping_box")) {
        setTimeout(() => {
          this.getSliderBoxesMaxHeight();

          /* On resize */
          var rtime;
          var timeout = false;
          var delta = 200;
          $(window).resize(function () {
            rtime = new Date();
            if (timeout === false) {
              timeout = true;
              setTimeout(resizeend, delta);
            }
          });

          function resizeend() {
            if (new Date() - rtime < delta) {
              setTimeout(resizeend, delta);
            } else {
              timeout = false;
              main.getSliderBoxesMaxHeight();
            }
          }
        }, 2000);
      }
    },
    getSliderBoxesMaxHeight: function () {
      return;
      var maxHeight = 0;

      if (
        $("body").width() < 1020 ||
        (jQuery(".sliderBoxes li.fusion_builder_column").length > 3 &&
          $(".custom-nav-prev").length == 0)
      ) {
        $(".sliderBoxes .fusion-builder-row").append(
          "<span class='custom-nav-prev'></span>"
        );
        $(".sliderBoxes .fusion-builder-row").append(
          "<span class='custom-nav-next'></span>"
        );

        $(".custom-nav-prev").on("click", function () {
          $(".fusion-nav-prev").trigger("click");
          setTimeout(() => {
            main.getSliderBoxesMaxHeight();
          }, 1000);
        });

        $(".custom-nav-next").on("click", function () {
          $(".fusion-nav-next").trigger("click");
          setTimeout(() => {
            main.getSliderBoxesMaxHeight();
          }, 1000);
        });
      }

      document.documentElement.style.setProperty(
        "--sliderBoxes_height",
        "auto"
      );
      jQuery(".sliderBoxes li.fusion_builder_column").each(function (
        index,
        element
      ) {
        var _tmp = jQuery(this).height();
        if (_tmp > maxHeight) {
          maxHeight = _tmp;
        }
      });
      document.documentElement.style.setProperty(
        "--sliderBoxes_height",
        "400px"
      );

      document.documentElement.style.setProperty(
        "--sliderBoxes_height",
        maxHeight + "px"
      );
    },
    teamMembersHover: function () {
      if ($(".team_member").length > 0) {
        $(".team_member").each(function (index, element) {
          var primaryImage = $(this).find(".primary_image img").attr("src");
          var secondaryImage = $(this).find(".secondary_image img").attr("src");

          $(this).find(".fusion-image-switch-before").attr("src", primaryImage);
          $(this)
            .find(".fusion-image-switch-after")
            .attr("src", secondaryImage);
        });
      }
    },

    fixMenuPosition: function () {
      if ($(".off-canvas-content").length > 0) {
        var _top = jQuery(".off-canvas-content").outerHeight();
        jQuery("#wrapper").stop(true).animate({
          top: _top + "px"
        }, 400);

        // On .off-canvas-close click, revert the top to the original value
        jQuery(".off-canvas-close").on("click", function () {
          jQuery("#wrapper").css({ top: "" });
        });

        // Also execute on window resize end
        var resizeTimer;
        jQuery(window).on("resize", function () {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(function () {
            if (jQuery(".off-canvas-content").length > 0) {
              var _top = jQuery(".off-canvas-content").outerHeight();
              jQuery("#wrapper").css({ top: _top + "px" });
            }
          }, 200);
        });
      }
    }
  };
  main.init();
})(jQuery);