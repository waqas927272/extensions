{
  "manifest_version": 3,
  "name": "VIP Vet Job Scraper",
  "version": "1.0",
  "description": "Scrapes job data from Veterinary Innovative Partners careers page.",
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": [
    "https://vip-vet.com/*",
    "https://www.vip-vet.com/*",
    "https://boards.greenhouse.io/*",
    "https://job-boards.greenhouse.io/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://vip-vet.com/*",
        "https://www.vip-vet.com/*",
        "https://job-boards.greenhouse.io/*",
        "https://boards.greenhouse.io/*"
      ],
      "js": ["content.js"],
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["description-scraper.js", "greenhouse-description-scraper.js", "detail-extractor.js", "google-maps-scraper.js", "google-search-scraper.js", "vipvet-greenhouse-content.js"],
      "matches": ["<all_urls>"]
    }
  ]
}

