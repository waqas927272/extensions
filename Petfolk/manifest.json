{
  "manifest_version": 3,
  "name": "Petfolk",
  "version": "2.0",
  "description": "Scrapes Petfolk job listings and descriptions from Rippling.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "webNavigation",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ats.rippling.com/petfolk/jobs*",
        "https://ats.rippling.com/*/petfolk/jobs*"
      ],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["description-scraper.js", "detail-extractor.js", "google-maps-scraper.js", "google-search-scraper.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
